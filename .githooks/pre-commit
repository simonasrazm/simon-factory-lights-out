#!/bin/sh
# SFLO pre-commit hook — run tests before every commit.
# Install: git config core.hooksPath .githooks

echo "Running SFLO tests..."

# Find python — prefer venv if available
if [ -f ".sflo/.venv/bin/python3" ]; then
    PY=".sflo/.venv/bin/python3"
elif [ -f "../.sflo/.venv/bin/python3" ]; then
    PY="../.sflo/.venv/bin/python3"
else
    PY="python3"
fi

# Run tests quietly — only show failures
$PY -m pytest tests/ -q 2>&1
STATUS=$?

if [ $STATUS -ne 0 ]; then
    echo ""
    echo "COMMIT BLOCKED: tests failed. Fix before committing."
    exit 1
fi

echo "Tests passed."
exit 0
